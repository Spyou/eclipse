                <item android:color="#40E65100" android:offset="0.92" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Dark eclipse body -->
    <path
        android:fillColor="#0D0D1A"
        android:pathData="M31,54 a23,23,0,1,0,46,0 a23,23,0,1,0,-46,0z" />

    <!-- Subtle inner rim glow -->
    <path android:pathData="M31,54 a23,23,0,1,0,46,0 a23,23,0,1,0,-46,0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="23">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#00000000" android:offset="0.88" />

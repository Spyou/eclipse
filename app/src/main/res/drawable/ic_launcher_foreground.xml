    <!-- Red play button (rounded rectangle) -->
    <path
        android:fillColor="#E53935"
        android:pathData="M45,36 L63,36 Q67,36,67,40 L67,52 Q67,56,63,56 L45,56 Q41,56,41,52 L41,40 Q41,36,45,36 Z" />

    <!-- White play triangle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M49,40 L61,46 L49,52 Z" />

    <!-- White download arrow (shaft + arrowhead) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52,58 L56,58 L56,62 L62,62 L54,70 L46,62 L52,62 Z" />

    <!-- White download tray -->
    <path

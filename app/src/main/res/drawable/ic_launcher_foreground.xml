                android:centerY="54"
                android:gradientRadius="36">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#00000000" android:offset="0.55" />
                <item android:color="#25FF8C00" android:offset="0.72" />
                <item android:color="#10FF6D00" android:offset="0.88" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Corona ring (bright amber/gold) -->
    <path android:pathData="M22,54 a32,32,0,1,0,64,0 a32,32,0,1,0,-64,0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="32">
                <item android:color="#00000000" android:offset="0.0" />
                <item android:color="#00000000" android:offset="0.65" />
                <item android:color="#80FF8C00" android:offset="0.70" />
                <item android:color="#FFFFA726" android:offset="0.75" />
                <item android:color="#FFFFC107" android:offset="0.78" />
                <item android:color="#FFFFA726" android:offset="0.80" />
